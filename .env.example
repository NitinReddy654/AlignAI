# AlignAI Environment Configuration
# Author: Nitin Reddy Bommidi

# Required for LLM-as-a-Judge evaluation
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model used for automated evaluation
OPENAI_JUDGE_MODEL=gpt-4o-mini

# Hugging Face token (optional, for private models/datasets)
HF_TOKEN=

# Base model identifiers (Qwen2.5 family)
ALIGNAI_BASE_MODEL_LORA=Qwen/Qwen2.5-3B-Instruct
ALIGNAI_BASE_MODEL_FFT=Qwen/Qwen2.5-0.5B-Instruct

# Paths
ALIGNAI_DATA_DIR=./data
ALIGNAI_ARTIFACTS_DIR=./data/artifacts
ALIGNAI_CHECKPOINTS_DIR=./checkpoints
ALIGNAI_EXPERIMENTS_DIR=./data/artifacts/experiments

# Training defaults
ALIGNAI_SEED=42
ALIGNAI_MAX_SEQ_LENGTH=2048

# Cost estimation (USD per GPU-hour, for reporting only)
ALIGNAI_GPU_HOUR_COST=0.50

# Logging
ALIGNAI_LOG_LEVEL=INFO
